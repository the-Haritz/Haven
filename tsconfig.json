{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    "module": "nodenext",
    "target": "ES2022",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,

    // We need @types/node for the Node.js runtime types
    "types": ["node"],
    "lib": ["ES2022"],

    // Output Settings
    "sourceMap": true,
    "declaration": true,

    // Strict Typechecking — keep it tight
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Helps catch mistakes
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // Required for Prisma and other CommonJS interop
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
