# ═══════════════════════════════════════════════════════════════
# Haven MVP — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# In development, sensible defaults are provided.
# In production (NODE_ENV=production), all values are REQUIRED.
# ═══════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info        # debug | info | warn | error

# ─── Database (Prisma) ───────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Blockchain RPC ──────────────────────────────────────────
# Use Alchemy or Infura for reliability. Public RPCs are rate-limited.
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532       # Base Sepolia

# ─── HD Wallet (BIP-39 Mnemonic) ─────────────────────────────
# ⚠️  NEVER commit a real mnemonic to version control.
# The default below is the well-known Hardhat test mnemonic.
MASTER_MNEMONIC="test test test test test test test test test test test junk"

# ─── Hot Wallet ──────────────────────────────────────────────
# The central wallet that processes user withdrawals.
# ⚠️  NEVER commit a real private key to version control.
HOT_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
HOT_WALLET_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# ─── Sweeper Configuration ───────────────────────────────────
MIN_SWEEP_THRESHOLD=0.005    # in ETH — ignore wallets below this

# ─── Block Explorer ──────────────────────────────────────────
EXPLORER_BASE_URL=https://sepolia.basescan.org
